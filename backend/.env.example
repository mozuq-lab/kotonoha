# =============================================================================
# kotonoha Backend 環境変数設定ファイル
# =============================================================================
# このファイルを .env にコピーして、実際の値を設定してください。
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# データベース設定
# -----------------------------------------------------------------------------
POSTGRES_USER=kotonoha_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=kotonoha_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# API設定
# -----------------------------------------------------------------------------
SECRET_KEY=your_secret_key_here_please_change_this_to_random_string
API_HOST=0.0.0.0
API_PORT=8000
API_V1_STR=/api/v1
PROJECT_NAME=kotonoha API
VERSION=1.0.0

# -----------------------------------------------------------------------------
# 環境設定
# -----------------------------------------------------------------------------
ENVIRONMENT=development  # development, staging, production（正確な表記のみ許可。誤記は起動時エラーで拒否）

# -----------------------------------------------------------------------------
# CORS設定
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------------------------------------------------
# 認証設定
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8日間 (60 * 24 * 8)

# 端末APIキー認証（AI変換APIの保護用）
# カンマ区切りで複数指定可。各端末に異なるキーを発行することを推奨。
# 未設定の場合、development/test では認証スキップ、それ以外（staging/production等）は
# 全リクエストを拒否（フェイルクローズ）。
# 例: API_KEYS=device-key-aaaa,device-key-bbbb
API_KEYS=

# Flutterビルド時に使用する値
# API_BASE_URLはデプロイ先バックエンドURL、AI_API_KEYは上記API_KEYSのいずれかを指定してください。
API_BASE_URL=http://localhost:8000
AI_API_KEY=

# -----------------------------------------------------------------------------
# セッション設定
# -----------------------------------------------------------------------------
SESSION_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# レート制限設定
# -----------------------------------------------------------------------------
# AI変換APIのレート制限: RATE_LIMIT_TIMES 回 / RATE_LIMIT_SECONDS 秒 / IP
RATE_LIMIT_TIMES=1
RATE_LIMIT_SECONDS=10

# 信頼するリバースプロキシ段数。
# 0=X-Forwarded-Forを信頼しない（接続元IPで制限）。本番でALB/nginx等の背後に置く場合は
# 自身が運用するプロキシ段数（通常1）を設定し、ヘッダー偽装によるレート制限回避を防ぐ。
TRUSTED_PROXY_COUNT=0

# -----------------------------------------------------------------------------
# ログ設定
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE_PATH=logs/app.log

# -----------------------------------------------------------------------------
# AI変換機能設定（Anthropic - 推奨）
# -----------------------------------------------------------------------------
# Anthropic Claude APIを使用する場合は設定してください
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
DEFAULT_AI_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# AI変換機能設定（OpenAI - オプション）
# -----------------------------------------------------------------------------
# OpenAI API を使用する場合は設定してください
# OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# AI API共通設定
# -----------------------------------------------------------------------------
AI_API_TIMEOUT=30  # 秒
AI_MAX_RETRIES=3
